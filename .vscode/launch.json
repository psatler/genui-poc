{
    // Use IntelliSense to learn about possible attributes.
    // Hover to view descriptions of existing attributes.
    // For more information, visit: https://go.microsoft.com/fwlink/?linkid=830387
    "version": "0.2.0",
    "configurations": [

        {
            "name": "catalog_gallery",
            "request": "launch",
            "type": "dart"
        },
        {
            "name": "catalog_gallery with samples (macOS)",
            "request": "launch",
            "type": "dart",
            "deviceId": "macos",
            "toolArgs": [
                "--dart-entrypoint-args",
                "--samples=${workspaceFolder}/samples"
            ]
        },
        {
            "name": "catalog_gallery (profile mode)",
            "request": "launch",
            "type": "dart",
            "flutterMode": "profile"
        },
        {
            "name": "catalog_gallery (release mode)",
            "request": "launch",
            "type": "dart",
            "flutterMode": "release"
        }
    ]
}